# SuiteCRM WhatsApp Integration - Environment Configuration
# Copy this file to .env and customize values for your environment

# ===== WhatsApp API Integration =====
# URL of the WhatsApp API service
WHATSAPP_API_URL=https://wa-api.grupoamericainterior.com.ar

# Webhook token for authenticating incoming messages
# Generate a strong token: openssl rand -hex 32
WHATSAPP_WEBHOOK_TOKEN=your_secure_token_here

# Webhook secret (optional)
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret_here

# ===== SuiteCRM Instance =====
# URL of this SuiteCRM instance (for whatsapp-api to reach back)
SUITECRM_URL=https://crm.grupoamericainterior.com.ar

# Webhook path in SuiteCRM
SUITECRM_WEBHOOK_PATH=/api/v8/webhook/whatsapp

# ===== Logging =====
# Log level: debug, info, warn, error
WHATSAPP_LOG_LEVEL=info

# ===== API Credentials (optional, for internal calls) =====
# User for internal SuiteCRM API calls
SUITECRM_API_USER=webhook_service

# Password for internal SuiteCRM API calls
SUITECRM_API_PASSWORD=service_password
